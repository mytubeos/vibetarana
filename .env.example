# Telegram API credentials — get from https://my.telegram.org (API development tools)
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Bot account — get from @BotFather on Telegram (/newbot)
BOT_TOKEN=123456789:AAExampleTokenStringHere

# Your personal Telegram user_id (numeric) — becomes the default owner.
# Get it by messaging @userinfobot on Telegram. Promote others to sudo via /addsudo.
OWNER_ID=123456789

# Assistant userbot session string(s) — comma-separated, one per assistant account.
# Generate each with: python scripts/generate_session.py
# Start with one; add more later to scale to more concurrent voice chats.
ASSISTANT_SESSIONS=

# MongoDB connection string — free tier at https://cloud.mongodb.com (M0 cluster)
# Actually used in TG2 (sudo users, per-chat settings) — unlike TG, where it was
# only declared and never connected.
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/tg2_musicbot

# Optional: numeric chat_id of a private log group/channel the bot should post startup/error logs to.
# Leave blank to disable.
LOG_GROUP_ID=

# Optional: enables Spotify link support (bot/platforms/spotify.py). Free —
# create an app at https://developer.spotify.com/dashboard to get these.
# Leave both blank to disable; Spotify links just won't resolve (Apple Music
# and SoundCloud links work either way, no credentials needed for those).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional tuning (safe defaults below)
DURATION_LIMIT_MIN=60
MAX_VC_PER_ASSISTANT=1
DEFAULT_LANG=en
